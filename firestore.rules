rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isSignedIn() {
      return request.auth != null;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isValidScore(data) {
      return data.keys().hasAll(['uid', 'score', 'updatedAt']) 
        && data.keys().size() == 3
        && data.uid is string && data.uid.size() <= 128
        && data.score is number
        && data.updatedAt == request.time;
    }

    match /scores/{scoreId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() 
        && isValidScore(incoming()) 
        && incoming().uid == request.auth.uid
        && scoreId == request.auth.uid;
        
      allow update: if isSignedIn() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['score', 'updatedAt'])
        && incoming().uid == request.auth.uid
        && existing().uid == request.auth.uid
        && incoming().updatedAt == request.time
        && incoming().score is number;
        
      allow delete: if false;
    }
  }
}
